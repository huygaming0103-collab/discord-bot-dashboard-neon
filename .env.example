# ================================================================
#  HDGBot Dashboard — Environment Variables
# ================================================================
#  Copy this file to .env and fill in your values for local dev.
#  On Vercel → Project Settings → Environment Variables.
#  On Replit → Secrets panel (the lock icon).
# ================================================================

# ── Discord ──────────────────────────────────────────────────────
# Bot token — Discord Developer Portal → your app → Bot → Token
DISCORD_BOT_TOKEN=your_bot_token_here

# OAuth2 Client ID — already public, default is HDGBot's ID
DISCORD_CLIENT_ID=1446826370838560859

# OAuth2 Client Secret — Developer Portal → OAuth2 → Client Secret
DISCORD_CLIENT_SECRET=your_client_secret_here

# OAuth2 redirect path (must match Developer Portal Redirect URIs)
# Full URL must be: https://<your-domain>/api/auth/callback
DISCORD_REDIRECT_PATH=/api/auth/callback

# ── Session ──────────────────────────────────────────────────────
# Random secret used to sign session cookies.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string.
# Free options: https://neon.tech  or  https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Server ───────────────────────────────────────────────────────
# Port the API server listens on.
# Replit sets PORT automatically — you usually don't need to change this.
PORT=8080
NODE_ENV=development
